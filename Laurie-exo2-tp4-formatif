# Dans ce code, r0 est utilisé en tant que registre temporaire (comme ACC)

.text
ldi r0, 0
ld r1, (r0)      # r1 = x
ldi r0, 1
ld r2, (r0)      # r2 = y
// Votre code ici
# on laisse certain espace pour registres temporaires au besoin
ldi r5, 0        # compteur mult 2
ldi r6, 0        # compteur mult 3
ldi r7, 0        # compteur mult 4
ldi r8, 1        # constante 1
ldi r9, 3        # constante 3
ldi r10, 0       # constante 0 

add r1, r1, r8   # on skip à x = 1, car x = 0 est multiple de rien

loop:
sub r0, r2, r1   # y - x
brlz end         # x > y : fin 
add r0, r10, r10 # met les flags à 0 sans rien changer

ismultwo:
// Votre code ici
and r0, r1, r8   # si lsb(1) = 1, alors pas divisible par 2
brnz ismulthree
add r5, r5, r8   # a++

ismulthree:
// Votre code ici
mv r0, r1        # remet x dans r0  

sub3:
sub r0, r0, r9   # x -= 3
brz mul3         # si nul, alors multiple de 3
add r0, r0, r10  # mise a jour flags (NOP)
brlz ismulfour   # si r0 < 0, alors on passe à mul4
br sub3          # on refait r0 -=3

mul3:
add r6, r6, r8   # b++

ismulfour:
// Votre code ici
and r0, r1, r9   # si lsb(2,1) = 11, alors pas divisible par 4
brnz increment   # skip au prochain x
add r7, r7, r8   # c++

increment:
add r1, r1, r8   # x++
br loop          # recommence

end:
// Votre code ici
ldi r0, a        # load addr[a] dans r0
st (r0), r5      # store r5 à l'adresse pointée par r0 (a)
ldi r0, b        # load addr[b] dans r0
st (r0), r6      # store r6 à l'adresse pointée par r0 (b)
ldi r0, c        # load addr[c] dans r0
st (r0), r7      # store r7 à l'adresse pointée par r0 (c)

stop
.data
x: 0 // Borne inférieur
y: 7 // Borne supérieur
a: 0 // N multiples de 2 -> attendu: 7
b: 0 // N multiples de 3 -> attendu: 5
c: 0 // N multiples de 4 -> attendu: 3
